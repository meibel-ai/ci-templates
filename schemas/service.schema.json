{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Meibel Service Manifest",
  "description": "service.yaml schema for all meibel-ai domain repos. apiVersion: meibel.ai/v1",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "meibel.ai/v1"
    },
    "kind": {
      "type": "string",
      "const": "Service"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "team"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "team": { "type": "string", "minLength": 1 }
      }
    },
    "spec": {
      "type": "object",
      "required": ["tier", "repo", "language", "deployment", "slos"],
      "additionalProperties": false,
      "properties": {
        "tier": {
          "type": "integer",
          "enum": [1, 2, 3],
          "description": "1=critical, 2=standard, 3=best-effort"
        },
        "repo": {
          "type": "string",
          "pattern": "^meibel-ai/.+",
          "description": "GitHub repo in the form meibel-ai/repo-name"
        },
        "language": {
          "type": "string",
          "enum": ["python", "node", "go", "rust"]
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "framework": {
              "type": "string",
              "enum": ["standard", "rayservice", "kuberay"]
            },
            "gpu": {
              "type": "boolean"
            }
          }
        },
        "deployment": {
          "type": "object",
          "required": ["targets"],
          "additionalProperties": false,
          "properties": {
            "targets": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": ["dev-gcp", "dev-aws", "staging", "prod-gcp", "prod-aws", "hub-dev", "hub"]
              }
            },
            "progressive": {
              "type": "boolean",
              "description": "Enable Argo Rollouts canary. Incompatible with runtime.framework: rayservice."
            }
          }
        },
        "slos": {
          "type": "object",
          "required": ["availability", "latency_p99_ms"],
          "additionalProperties": false,
          "properties": {
            "availability": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "Target availability percentage, e.g. 99.9"
            },
            "latency_p99_ms": {
              "type": "integer",
              "minimum": 1,
              "description": "p99 latency target in milliseconds"
            }
          }
        }
      }
    }
  }
}
